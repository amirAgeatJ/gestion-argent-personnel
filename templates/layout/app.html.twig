{% extends 'layout/base.html.twig' %}

{% block body %}
    <body class="text-gray-800 font-sans antialiased bg-neutral flex min-h-screen">

    {% if app.user %}
        {% include 'layout/partials/app/sidenav.html.twig' %}
    {% endif %}

    <div class="flex-1 flex flex-col min-w-0">
        {% include 'layout/partials/app/topbar.html.twig' %}

        <main class="flex-1">
            {% for label, messages in app.flashes(['success', 'error']) %}
                {% for message in messages %}
                    <div class="max-w-6xl mx-auto mt-4 px-4">
                        <div class="rounded-lg px-4 py-3 text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' : 'bg-red-50 text-red-700 border border-red-200' }}">
                            {{ message }}
                        </div>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block content %}{% endblock %}
        </main>
    </div>

    </body>
{% endblock %}
