{% extends 'layout/base.html.twig' %}

{% block body %}
    <body class="text-gray-800 font-sans antialiased bg-gray-50 flex min-h-screen">

    {% include 'layout/partials/admin/sidebar.html.twig' %}

    <div class="flex-1 flex flex-col min-w-0">
        {% include 'layout/partials/admin/header.html.twig' %}

        <main class="flex-1 p-6">
            {% for label, messages in app.flashes(['success', 'error']) %}
                {% for message in messages %}
                    <div class="mb-4 rounded-lg px-4 py-3 text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' : 'bg-red-50 text-red-700 border border-red-200' }}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {% block content %}{% endblock %}
        </main>
    </div>

    </body>
{% endblock %}
