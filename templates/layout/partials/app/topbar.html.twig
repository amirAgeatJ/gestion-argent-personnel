<header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-6 gap-4">
    {% if app.user %}
        <div></div>

        <div class="flex items-center gap-4">
            <form method="get" action="{{ path('app_display_currency') }}" class="flex items-center">
                <input type="hidden" name="redirect" value="{{ app.request.requestUri }}">
                <select name="currency" onchange="this.form.submit()"
                        class="bg-brand text-white text-sm font-semibold rounded-full pl-4 pr-8 py-1.5 appearance-none cursor-pointer focus:outline-none focus:ring-2 focus:ring-brand/40">
                    {% for code in ['EUR', 'USD', 'GBP', 'CHF'] %}
                        <option value="{{ code }}" {{ display_currency() == code ? 'selected' : '' }}>{{ code }}</option>
                    {% endfor %}
                </select>
            </form>

            <a href="{{ path('app_notification_index') }}" class="text-gray-500 hover:text-brand" title="Notifications">
                <i class="fa-solid fa-bell"></i>
            </a>

            <div class="text-right hidden sm:block leading-tight">
                <div class="font-semibold text-sm text-gray-800">{{ app.user.fullName }}</div>
                <div class="text-xs text-gray-400">{{ app.user.email }}</div>
            </div>

            <div class="w-9 h-9 rounded-full bg-brand text-white flex items-center justify-center font-bold text-sm">
                {{ app.user.firstName|slice(0, 1)|upper }}
            </div>

            <form method="post" action="{{ path('app_logout') }}">
                <button class="text-sm font-semibold text-gray-500 hover:text-brand flex items-center gap-1">
                    <i class="fa-solid fa-arrow-right-from-bracket"></i>
                    <span class="hidden sm:inline">Déconnexion</span>
                </button>
            </form>
        </div>
    {% else %}
        <a href="{{ path('app_dashboard') }}" class="flex items-center gap-2 font-bold text-lg text-gray-800">
            <i class="fa-solid fa-piggy-bank text-brand"></i>
            Gestion Argent Personnel
        </a>
        <div class="flex items-center gap-3">
            <a href="{{ path('app_login') }}" class="text-sm font-semibold text-gray-600 hover:text-brand">Connexion</a>
            <a href="{{ path('app_register') }}" class="inline-flex items-center px-4 py-2 rounded-lg bg-brand text-white text-sm font-semibold hover:bg-brandHover">Créer un compte</a>
        </div>
    {% endif %}
</header>
