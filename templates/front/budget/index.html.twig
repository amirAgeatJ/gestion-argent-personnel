{% extends 'layout/app.html.twig' %}

{% block title %}Budgets - Gestion Argent Personnel{% endblock %}

{% block content %}
    <div class="max-w-4xl mx-auto px-4 py-8">
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-bold">Budgets - {{ monthStart|date('m/Y') }}</h1>
            <a href="{{ path('app_budget_new') }}" class="text-sm font-semibold text-white bg-brand rounded-lg px-4 py-2 hover:bg-brandHover">+ Nouveau budget</a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {% for entry in budgetsWithSpent %}
                {% set percent = entry.budget.limitAmount > 0 ? (entry.spent / entry.budget.limitAmount * 100)|round : 0 %}
                <div class="bg-white border border-gray-200 rounded-xl p-5">
                    <div class="flex justify-between items-start mb-2">
                        <div class="font-semibold">{{ entry.budget.category.name }}</div>
                        <div class="flex gap-2 text-xs">
                            <a href="{{ path('app_budget_edit', {id: entry.budget.id}) }}" class="text-gray-400 hover:text-brand"><i class="fa-solid fa-pen"></i></a>
                            <form method="post" action="{{ path('app_budget_delete', {id: entry.budget.id}) }}" onsubmit="return confirm('Supprimer ce budget ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ entry.budget.id) }}">
                                <button class="text-gray-400 hover:text-expense"><i class="fa-solid fa-trash"></i></button>
                            </form>
                        </div>
                    </div>
                    <div class="flex justify-between text-sm mb-1">
                        <span class="{{ percent >= 100 ? 'text-expense font-semibold' : 'text-gray-500' }}">{{ entry.spent|money() }} dépensés</span>
                        <span class="text-gray-500">sur {{ entry.budget.limitAmount|money() }}</span>
                    </div>
                    <div class="w-full bg-gray-100 rounded-full h-2">
                        <div class="h-2 rounded-full {{ percent >= 100 ? 'bg-expense' : 'bg-brand' }}" style="width: {{ percent > 100 ? 100 : percent }}%"></div>
                    </div>
                </div>
            {% else %}
                <div class="col-span-2 text-center py-10 bg-white border border-dashed border-gray-300 rounded-xl text-gray-500">
                    Aucun budget pour ce mois.
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
