{% extends 'layout/app.html.twig' %}

{% block title %}Mes comptes - Gestion Argent Personnel{% endblock %}

{% block content %}
    <div class="max-w-5xl mx-auto px-4 py-8">
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-bold">Mes comptes</h1>
            <div class="flex gap-2">
                {% for slug, info in types %}
                    <a href="{{ path('app_account_new', {type: slug}) }}" class="text-sm font-semibold text-brand border border-brand rounded-lg px-3 py-2 hover:bg-brand hover:text-white transition">
                        + {{ info[2] }}
                    </a>
                {% endfor %}
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {% for entry in accountsWithBalances %}
                <a href="{{ path('app_account_show', {id: entry.account.id}) }}" class="block bg-white border border-gray-200 rounded-xl p-5 shadow-sm hover:shadow-md transition">
                    <div class="text-xs uppercase tracking-wide text-gray-500">{{ entry.account.typeLabel }}</div>
                    <div class="font-semibold text-gray-800">{{ entry.account.name }}</div>
                    <div class="text-2xl font-bold mt-2 {{ entry.balance < 0 ? 'text-expense' : 'text-gray-900' }}">
                        {{ entry.balance|money(entry.account.currency) }}
                    </div>
                </a>
            {% else %}
                <div class="col-span-2 text-center py-10 bg-white border border-dashed border-gray-300 rounded-xl text-gray-500">
                    Vous n'avez encore aucun compte.
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
