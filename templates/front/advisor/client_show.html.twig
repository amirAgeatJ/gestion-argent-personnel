{% extends 'layout/app.html.twig' %}

{% block title %}{{ client.fullName }} - Gestion Argent Personnel{% endblock %}

{% block content %}
    <div class="max-w-4xl mx-auto px-4 py-8">
        <a href="{{ path('app_advisor_index') }}" class="text-sm text-gray-500 hover:text-brand">&larr; Retour à mes clients</a>
        <h1 class="text-2xl font-bold mt-2 mb-1">{{ client.fullName }}</h1>
        <p class="text-sm text-gray-500 mb-6">{{ client.email }} — accès en lecture seule</p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {% for entry in accountsWithBalances %}
                <div class="bg-white border border-gray-200 rounded-xl p-5">
                    <div class="text-xs uppercase tracking-wide text-gray-500">{{ entry.account.typeLabel }}</div>
                    <div class="font-semibold text-gray-800">{{ entry.account.name }}</div>
                    <div class="text-2xl font-bold mt-2 {{ entry.balance < 0 ? 'text-expense' : 'text-gray-900' }}">
                        {{ entry.balance|money(entry.account.currency) }}
                    </div>
                </div>
            {% else %}
                <div class="col-span-2 text-center py-10 bg-white border border-dashed border-gray-300 rounded-xl text-gray-500">
                    Ce client n'a aucun compte.
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
