{% extends 'layout/app.html.twig' %}

{% block title %}Mes clients - Gestion Argent Personnel{% endblock %}

{% block content %}
    <div class="max-w-3xl mx-auto px-4 py-8">
        <h1 class="text-2xl font-bold mb-6">Mes clients</h1>

        <div class="bg-white border border-gray-200 rounded-xl divide-y divide-gray-100">
            {% for assignment in assignments %}
                <a href="{{ path('app_advisor_client_show', {id: assignment.client.id}) }}" class="p-4 flex items-center justify-between text-sm hover:bg-gray-50">
                    <div>
                        <div class="font-medium">{{ assignment.client.fullName }}</div>
                        <div class="text-xs text-gray-400">{{ assignment.client.email }}</div>
                    </div>
                    <i class="fa-solid fa-chevron-right text-gray-300"></i>
                </a>
            {% else %}
                <div class="p-6 text-center text-gray-500 text-sm">Aucun client ne vous est assigné pour le moment.</div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
