{% extends 'layout/app.html.twig' %}

{% block title %}Notifications - Gestion Argent Personnel{% endblock %}

{% block content %}
    <div class="max-w-3xl mx-auto px-4 py-8">
        <h1 class="text-2xl font-bold mb-6">Notifications</h1>

        <div class="bg-white border border-gray-200 rounded-xl divide-y divide-gray-100">
            {% for notification in notifications %}
                <div class="p-4 flex items-center justify-between text-sm {{ notification.read ? 'text-gray-500' : 'text-gray-800 font-medium bg-gray-50' }}">
                    <div>
                        {{ notification.message }}
                        <div class="text-xs text-gray-400 mt-1">{{ notification.createdAt|date('d/m/Y H:i') }}</div>
                    </div>
                    {% if not notification.read %}
                        <form method="post" action="{{ path('app_notification_mark_read', {id: notification.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('read' ~ notification.id) }}">
                            <button class="text-xs font-semibold text-brand hover:underline">Marquer comme lue</button>
                        </form>
                    {% endif %}
                </div>
            {% else %}
                <div class="p-6 text-center text-gray-500 text-sm">Aucune notification.</div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
