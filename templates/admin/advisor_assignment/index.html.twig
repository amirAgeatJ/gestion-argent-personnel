{% extends 'layout/admin.html.twig' %}
{% set pageTitle = 'Conseillers' %}

{% block title %}Conseillers - Administration{% endblock %}

{% block content %}
    <div class="flex justify-end mb-4">
        <a href="{{ path('admin_advisor_assignment_new') }}" class="text-sm font-semibold text-white bg-brand rounded-lg px-4 py-2 hover:bg-brandHover">+ Nouvelle assignation</a>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl divide-y divide-gray-100">
        {% for assignment in assignments %}
            <div class="p-4 flex items-center justify-between text-sm">
                <div>
                    <strong>{{ assignment.advisor.fullName }}</strong> conseille <strong>{{ assignment.client.fullName }}</strong>
                    <div class="text-xs text-gray-400">depuis le {{ assignment.assignedAt|date('d/m/Y') }}</div>
                </div>
                <form method="post" action="{{ path('admin_advisor_assignment_delete', {id: assignment.id}) }}" onsubmit="return confirm('Supprimer cette assignation ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ assignment.id) }}">
                    <button class="text-gray-400 hover:text-expense"><i class="fa-solid fa-trash"></i></button>
                </form>
            </div>
        {% else %}
            <div class="p-6 text-center text-gray-500 text-sm">Aucune assignation.</div>
        {% endfor %}
    </div>
{% endblock %}
