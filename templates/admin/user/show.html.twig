{% extends 'layout/admin.html.twig' %}
{% set pageTitle = user.fullName %}

{% block title %}{{ user.fullName }} - Administration{% endblock %}

{% block content %}
    <a href="{{ path('admin_user_index') }}" class="text-sm text-gray-500 hover:text-brand">&larr; Retour aux utilisateurs</a>

    <div class="bg-white border border-gray-200 rounded-xl p-6 mt-4 max-w-2xl">
        <div class="flex items-center justify-between mb-4">
            <div>
                <h2 class="text-xl font-bold">{{ user.fullName }}</h2>
                <p class="text-sm text-gray-500">{{ user.email }}</p>
            </div>
            <form method="post" action="{{ path('admin_user_toggle_status', {id: user.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('status' ~ user.id) }}">
                <button class="text-sm font-semibold px-3 py-2 rounded-lg border {{ user.status == 'active' ? 'border-red-200 text-expense hover:bg-red-50' : 'border-emerald-200 text-income hover:bg-emerald-50' }}">
                    {{ user.status == 'active' ? 'Suspendre' : 'Réactiver' }}
                </button>
            </form>
        </div>

        <h3 class="text-sm font-semibold text-gray-700 mb-2">Rôles</h3>
        <div class="flex flex-wrap gap-2 mb-4">
            {% for role in user.assignedRoles %}
                <form method="post" action="{{ path('admin_user_role_remove', {id: user.id}) }}" class="inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('role_remove' ~ user.id) }}">
                    <input type="hidden" name="roleCode" value="{{ role }}">
                    <button class="text-xs px-2 py-1 rounded-full bg-brand/10 text-brand font-semibold hover:bg-red-50 hover:text-expense">
                        {{ availableRoles[role]|default(role) }} &times;
                    </button>
                </form>
            {% else %}
                <span class="text-sm text-gray-400">Utilisateur standard (aucun rôle additionnel)</span>
            {% endfor %}
        </div>

        <form method="post" action="{{ path('admin_user_role_assign', {id: user.id}) }}" class="flex items-center gap-2">
            <input type="hidden" name="_token" value="{{ csrf_token('role_assign' ~ user.id) }}">
            <select name="roleCode" class="text-sm border border-gray-200 rounded-lg px-3 py-2">
                {% for code, label in availableRoles %}
                    <option value="{{ code }}">{{ label }}</option>
                {% endfor %}
            </select>
            <button class="text-sm font-semibold text-white bg-brand rounded-lg px-3 py-2 hover:bg-brandHover">Attribuer</button>
        </form>
    </div>
{% endblock %}
